classdiagram EBikeSystem {

  class EBike {
    Frame frame;
    DriveSystem driveSystem;
    Controller controller;
    Battery battery;
  }

  class Frame {
    String steel;
  }

  class Wheel {}

  class DriveSystem {
    Motor motor;
  }

  class Motor {}

  class Controller {
    Battery battery;
    State currentState;
  }

  class BasicController extends Controller {}

  class AdvancedController extends Controller {}

  class Battery {
    float storedEnergy;
  }

  enum State {
    On,
    Off,
    Charging;
  }

  association [1] EBike -> (wheel) Wheel [*];
  association [1] EBike -> (battery) Battery [1];
  association [1] EBike -> (frame) Frame [1];
  association [1] EBike -> (driveSystem) DriveSystem [1];
  association [1] EBike -> (controller) Controller [1];

  association [1] DriveSystem -> (motor) Motor [1];

  association [1] Controller -> (battery) Battery [1];
  association [1] Controller -> (currentState) State [1];
}
