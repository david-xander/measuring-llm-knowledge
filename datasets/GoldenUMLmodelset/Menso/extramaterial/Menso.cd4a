/* (c) Conversion from PlantUML to CD4A */

classdiagram Menso {

  class BusLine {
    String destination;
  }

  class PriceCategory {
    Double price;
  }

  class Trajectory {
    String status;
  }

  class Bus {
  }

  class BusOnTrajectory {
  }

  class Trip {
  }

  class MensoTicket {
  }

  class MensoTrip {
    DateTime tripDateTime;
  }

  class InvoiceLine {
  }

  class Invoice {
    Double total;
    Double discount;
  }

  class Customer {
    String name;
    String homeAddress;
    String officeAddress;
    String workingHours;
  }

  // Associations
  association [*] BusLine -> PriceCategory [0..1];
  association [1] BusLine -> Trajectory [*];
  association [1] Trajectory -> BusOnTrajectory [*];
  association [1] Bus -> BusOnTrajectory [*];
  association [1] BusOnTrajectory -> Trip [*];
  association [1] MensoTicket -> MensoTrip [*];
  association [1] BusOnTrajectory -> MensoTrip [*];
  association [1] MensoTrip -> InvoiceLine [0..1];
  association [1] Invoice -> InvoiceLine [*];
  association [1] Customer -> MensoTicket [*];
  association [1] MensoTicket -> Invoice [*];
}
