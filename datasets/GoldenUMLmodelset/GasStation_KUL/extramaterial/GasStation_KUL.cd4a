/* Converted from PlantUML to CD4A */

classdiagram GasStation_KUL {

  class CardHolder {
    String name;
    Boolean suspended;
  }

  class Invoice {
    int number;
    double discount;
    String status;
  }

  class InvoiceLine {
    int number;
  }

  class GasStation {
    String name;
  }

  class Pump {
    String type;
    Boolean inUse;
    double refillThreshold;
    Boolean blocked;
  }

  class RefuelTurn {
    int refuelTurnNumber;
  }

  class CashTurn {}

  association [1] Pump -> RefuelTurn [*];
  association [1] Pump -> CashTurn [*];
  association [1] GasStation -> Pump [*];
  association [1] CardHolder -> Invoice [*];
  association [1] CardHolder -> RefuelTurn [*];
  association [1] Invoice -> InvoiceLine [*];
  association [1] RefuelTurn -> InvoiceLine [0..1];

}
