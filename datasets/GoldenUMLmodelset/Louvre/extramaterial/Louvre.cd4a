classdiagram Louvre {

  class Collector {}

  class Piece {
    String Title;
    String Description;
  }

  class Item {
    String Description;
  }

  class Exhibition {
    String Title;
    String Stage;
  }

  class Location {}

  class Room {}

  class Employee {
    String Level;
  }

  association [1] Collector -> Piece [*];
  association [*] Piece -> Item [*];
  association [1] Exhibition -> Item [*];
  association Coordinator [1] Employee -> Exhibition [*];
  association [*] Exhibition -> (AssignedLocation) Location [0..1];
  association RoomLocationAssignment [*] Location <-> Room [*];
  association hasCoach [*] Employee -> Employee [0..1];
}
