/* Converted from PlantUML to CD4A */

classdiagram TrackLogistics {

  class Assignment {
    java.util.Date date;
  }

  class Location {
    String address;
  }

  class Driver {
    String firstName;
    String lastName;
  }

  class Vehicle {
    int vehicleNumber;
  }

  class Truck extends Vehicle {
    double tonnage;
  }

  class PassengerCar extends Vehicle {
    int seats;
  }

  class Transporter extends Vehicle {}

  enum VehicleStatus {
    READY,
    ASSIGNMENT,
    MAINTENANCE;
  }

  association executes [0..1] Assignment -> Driver [*];
  association from [*] Assignment -> Location [1];
  association to [*] Assignment -> Location [1];

  association [1] Location -> Vehicle [1];

  association [1..*] Driver -> Vehicle [*];
  association [0..1] Vehicle -> Driver [*];

  association status [1] Vehicle -> (status) VehicleStatus [1];
}
