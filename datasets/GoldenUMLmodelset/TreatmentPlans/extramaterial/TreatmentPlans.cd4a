/* Converted from PlantUML to CD4A */

classdiagram TreatmentPlans {

  class ProblemType {
    String Type;
  }

  class TreatmentPlan {}

  class AdvisedExaminationType {}

  class ExaminationType {
    String Type;
  }

  class Diagnosis {}

  class Treatment {}

  class AdvisedExamination {}

  class Permission {}

  class Consultation {}

  class FreeExamination {}

  class Patient {}

  class Affiliation {}

  class Doctor {}

  class Hospital {}

  // Associations
  association [1] ProblemType -> (treatmentPlan) TreatmentPlan [0..1];
  association [*] TreatmentPlan <-> (examinations) ExaminationType [*];
  association [1] ProblemType -> (diagnoses) Diagnosis [*];
  association [1] TreatmentPlan -> (treatments) Treatment [*];

  association [1] Diagnosis -> (treatments) Treatment [*];
  association [1] Diagnosis <-> (consultations) Consultation [*];
  association [1] Treatment -> (advisedExaminations) AdvisedExamination [*];
  association [1] Treatment <-> (freeExaminations) FreeExamination [*];

  association [1] AdvisedExaminationType <-> (advisedExaminations) AdvisedExamination [*];

  association [1] AdvisedExamination -> (permission) Permission [1];
  association [1] FreeExamination -> (permission) Permission [1];
  association [1] ExaminationType <-> (permissions) Permission [*];

  association [1] Consultation -> (affiliation) Affiliation [1];
  association [1] Consultation -> (patient) Patient [1];

  association [1] Affiliation -> (doctor) Doctor [1];
  association [1] Affiliation -> (hospital) Hospital [1];
  association [1] Permission -> (hospital) Hospital [1];
}
