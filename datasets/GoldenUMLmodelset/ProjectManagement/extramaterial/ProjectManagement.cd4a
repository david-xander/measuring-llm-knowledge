classdiagram ProjectManagement {

class ResearchGroup {}

class Department {}

class Researcher {}

class Project {}

class WorkPackage {}

class WorkPackageLeader {}

class Service {}


association [1] Department -> ResearchGroup [*];
association [1] ResearchGroup -> Researcher [*];
association [1] Project -> WorkPackage [1..*];
association [*] WorkPackage -> ResearchGroup [0..1];
association [1] Researcher -> Service [*];
association [1] WorkPackageLeader -> Service [*];

}

