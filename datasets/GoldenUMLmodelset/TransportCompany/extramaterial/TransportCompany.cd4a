classdiagram TransportCompany {

  class RepairShop {
    String name;
    String address;
  }

  class Repair {
    int duration;
    double cost;
  }

  class Vehicle {
    String licensePlateNumber;
    int milage;
    VehicleType type;
  }

  class Order {
    int packetSize;
    Date date;
    String comment;
    DateTime startTime;
    DateTime endTime;
    String pickUpAddress;
    String deliveryAddress;
  }

  abstract class Employee {
    int ssn;
    String firstName;
    String lastName;
  }

  class Driver extends Employee {}

  abstract class OtherEmployee extends Employee {
    String userName;
    String password;
  }

  class Planner extends OtherEmployee {}

  class AdministrationEmployee extends OtherEmployee {
    String fieldOfActivity;
  }

  class PartnerFirm {
    String name;
    String address;
  }

  class Customer {
    String name;
    String address;
  }

  enum VehicleType {
    REFRIGERATED_TRUCK,
    SMALL_VAN,
    LOADING_PLATFORM,
    BOX_TRUCK;
  }

  // Associations
  association [1] RepairShop -> Repair [*];
  association [*] Repair -> Vehicle [1];
  association [*] Repair -> Employee [1];
  association [1] Vehicle -> Order [*];
  association [1] Driver -> Order [*];
  association [1] Planner -> Order [*];
  association [0..1] AdministrationEmployee -> Order [*];
  association [*] Order -> PartnerFirm [0..1];
  association [*] Order -> Customer [1];
}
