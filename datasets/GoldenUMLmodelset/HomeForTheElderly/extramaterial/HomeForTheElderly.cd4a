/* (c) conversion from PlantUML to CD4A */

classdiagram HomeForTheElderly {

  class Department {}

  class Category {
    Double price;
    String type;
  }

  class Room {}

  class Bed {}

  class Proposal {
    String status;
    Boolean validated;
  }

  class Stay {
    Date intakeDate;
    Date endDate;
  }

  class Person {
    String name;
    Date birthdate;
    Date registrationDate;
    String abilities;
  }

  class Invoice {
    Date invoiceDate;
    Double outstandingAmount;
    String status;
  }

  class InvoiceItem {}

  class InvoiceLine {}

  // Associations
  association [1] Department -> Room [*];
  association [1] Category -> Room [*];
  association [1] Room -> Bed [*];
  association [0..1] Bed -> Person [0..1];
  association [1] Person -> Stay [*];
  association [1] Bed -> Stay [*];
  association [1] Person -> Invoice [*];
  association [1] Invoice -> InvoiceLine [*];
  association [1] InvoiceItem -> InvoiceLine [0..1];
  association [1] Stay -> InvoiceItem [*];
}
