/* Converted from PlantUML */

classdiagram CardGameApp {

  class Game {
    int ID;
  }

  class Player {
    int ID;
  }

  class Deck {
    int ID;
  }

  class Card {
    int ID;
    Suit suit;
    Compare compare;
  }

  class Scoreboard {
    int ID;
  }

  class Round {
    int ID;
    int points;
  }

  abstract class RoundType {
    int ID;
  }

  class SoloRound extends RoundType {
    SoloType solo;
  }

  class MandatorySolo extends SoloRound {}

  class DoubleRound extends RoundType {}

  enum Suit {
    DIAMONDS,
    HEARTS,
    SPADES,
    CLUBS;
  }

  enum Compare {
    LOWER,
    HIGHER,
    EQUAL;
  }

  enum SoloType {
    TRUMP,
    JACKS,
    QUEENS;
  }

  association [1] Game -> Scoreboard [1];
  association [1] Game -> Deck [1];
  association [1] Game -> Player [4];

  association [1] Deck -> Card [0..48];

  association [1] Scoreboard -> Round [*];

  association [1] Player -> Round [1..3];
  association [1] Player -> RoundType [1..2];

  association [1] Card -> Suit [1];
  association [1] Card -> Compare [1];
  association [1] SoloRound -> SoloType [1];
}
