/* Converted from PlantUML to CD4A */

classdiagram BuildingPortal {

  class User {
    String username;
    String password;
    String email;
  }

  class Administrator extends User {
    String idCardNumber;
  }

  class WebPortal {
    String versionNumber;
    String url;
  }

  class Building {
    String id;
    String label;
    String address;
    int yearOfConstruction;
  }

  class Entry {
    String name;
    boolean isPublic;
  }

  class TextEntry extends Entry {
    String text;
  }

  class NumericEntry extends Entry {
    double value;
    String unit;
  }

  class EntryGroup {}

  enum EnergyClass {
    A,
    B,
    C,
    D;
  }

  class Comment {
    String text;
  }

  class Image {
    String fileName;
  }

  association [1] WebPortal -> (id) Entry [*];
  association [0..1] WebPortal -> (username) User [1];
  association [1] EntryGroup -> Entry [*];

  association [1] User -> (owner) Building [*];
  association [1] User -> (author) Building [*];
  association [1] Building -> Comment [*];
  association [1] Building -> (profilePicture) Image [1];
  association [1] Building -> EnergyClass [1];

}
