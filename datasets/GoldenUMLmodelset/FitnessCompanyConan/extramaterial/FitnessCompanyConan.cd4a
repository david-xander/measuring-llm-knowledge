classdiagram FitnessCompanyConan {

  class Center {
    String name;
    String address;
  }

  class Room {
    int roomNr;
    int maxCapacity;
  }

  class Session {
    Date startDateTime;
  }

  class IndividualSession extends Session {}

  class GroupSession extends Session {
       String type;
     }

  class Person {
    String firstName;
    String lastName;
    Date birthDate;
  }

  class Member extends Person {}

  class Trainer extends Person {
    String diploma;
  }

  association [1] Center -> Room [1..*];
  association [1] Room -> Session [*];
  association [*] IndividualSession -> Member [1];
  association [*] Member <-> GroupSession [*];
  association [1] Trainer -> GroupSession [*];
}
