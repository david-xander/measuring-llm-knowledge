classdiagram PizzaDeliveryWithEntertainment {

  class User {
    int userID;
    Date birthdate;
    String name;
    String address;
  }

  class Customer extends User {
    String deliveryAddress;
  }

  class BusinessOwner extends User {
    String linkedInAccout;
  }

  class Entertainer extends User {
    String stageName;
    String bio;
    double priceThirtyMin;
  }

  class Order {
    int orderID;
    DateTime orderPlacement;
    DateTime latestDelivery;
    int numberOfPeople;
  }

  class EntertainmentOrder extends Order {
    String entertainmentType;
    int duration;
  }

  class PizzaRestaurant {
    int zipCode;
    String address;
    String phoneNumber;
    String website;
    String openingHours;
  }

  class Pizza {
    String name;
    String crustStructure;
    double price;
  }

  class Employment {
    String availability;
  }

  association [1] Customer -> Order [*];
  association [1] BusinessOwner -> PizzaRestaurant [*];
  association [*] PizzaRestaurant -> Pizza [*];
  association [*] Order -> PizzaRestaurant [1];
  association [*] Order -> Pizza [*];
  association [*] PizzaRestaurant -> Entertainer [*];
  association [1] Entertainer -> EntertainmentOrder [*];
}
