/* Converted from PlantUML to CD4A */

classdiagram Sober {

  class Ride {
    int rideNr;
    DateTime pickupDateTime;
    DateTime dropoffDateTime;
    int duration;
    String pickupLocation;
    String dropoffLocation;
    int distance;
    int fee;
  }

  class RideHailing extends Ride {
    int passengers;
    DateTime waitTime;
    String requestType;
  }

  class RideSharing extends Ride {}

  class Customer {
    int custNr;
    String custName;
  }

  class Car {
    int carNr;
    String carType;
  }

  class SoberCar extends Car {}

  class OtherCar extends Car {}

  class Involved {
    int damageAmount;
  }

  class Accident {
    int accNr;
    String accLocation;
    DateTime accDateTime;
  }

  // Associations
  association [*] RideHailing -> Customer [1];
  association [*] RideSharing -> Customer [1];
  association [*] Ride -> Car [1];
  association [*] OtherCar -> Customer [1];
  association [1..*] Car -> Accident [*];
}
