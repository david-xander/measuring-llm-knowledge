/* (c) Conversion from PlantUML to CD4A */

classdiagram House {

  class ConcreteBasement extends Basement {
    Double Quality;
  }

  abstract class Basement {
    Double Size;
    String Name;
  }

  enum BMType {
    WOOD,
    BRICK,
    CONCRETE;
  }

  class EarthBasement extends Basement {
    Double Humidity;
  }

  abstract class SemiDetached extends House {
    Boolean Garden;
    int Windows;
  }

  class House {
    String Address;
    BMType BuildingMaterial;
  }

  class JobLog {
    int Hours;
    Double Price;
  }

  class SemiDetachedWithCarport extends SemiDetached {}

  class SemiDetachedWithGarage extends SemiDetached {}

  class Company {
    String Name;
    String Address;
  }

  class Carport {
    Boolean DoublePort;
    Boolean flatRoof;
  }

  class Garage {
    Boolean Automatic;
  }

  association [0..1] Basement -> (house) House [1];
  association [*] House -> Company [*];
  association [1] SemiDetachedWithCarport -> Carport [2];
  association [1] SemiDetachedWithGarage -> Garage [1];
}
