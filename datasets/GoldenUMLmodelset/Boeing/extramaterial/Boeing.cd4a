/* (c) converted from PlantUML by CD4A Class Diagram Creator */

classdiagram Boeing {

  class AirplaneModel {
    int modelId;
  }

  class Airplane {
    int airplaneId;
  }

  class Acquisition {
    int acquisitionId;
    float negotiatedPice;
    String options;
    Date deliveryDate;
  }

  class Contract {
    int contractId;
    String text;
  }

  class Employee {
    int employeeId;
  }

  class Airline {
    String name;
  }

  // Associations
  association [1] AirplaneModel -> Airplane [*];
  association [0..1] Airplane -> (part_of) Acquisition [0..1];
  association [*] Acquisition -> (part_of) Contract [1];
  association [*] Contract -> Airline [1];
  association [*] Contract -> Employee [1];
  association [0..1] Airline -> Airline [*];
}
