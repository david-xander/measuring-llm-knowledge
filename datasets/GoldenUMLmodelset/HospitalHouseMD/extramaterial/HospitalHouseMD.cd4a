/* (c) conversion from PlantUML to CD4A */

classdiagram HospitalHouseMD {

  class Patient {
    Boolean consent;
  }

  class Doctor {}

  class Diagnosis {
    int stage;
  }

  class Illness {
    String priority;
  }

  class Treatment {}

  class AppliedTreatment {}

  association [1] Patient -> Diagnosis [*];
  association [1] Doctor -> Diagnosis [*];
  association [1] Illness -> Diagnosis [*];
  association [1] Diagnosis -> AppliedTreatment [*];
  association [1] Illness -> Treatment [*];
  association [1] Treatment -> AppliedTreatment [*];
}
