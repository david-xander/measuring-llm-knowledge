{
  "_comment": "SLE 2026 Artifact — Experiment configuration. name = argument passed to run_analysis(). dataset_path = expected location of the dataset file/folder (for documentation). folder = extra instance attribute required by some run classes.",
  "output": {
    "results_dir": "results",
    "analysis_dir": "analysis"
  },
  "languages": {
    "lua": {
      "run_module": "lua",
      "grammar": {
        "lexer_g4": "languages/lua/parser/LuaLexer.g4",
        "parser_g4": "languages/lua/parser/LuaParser.g4"
      },
      "datasets": [
        {
          "name": "lua-00000-of-00001.parquet",
          "run_class": "BaseLineAnalysisMultiplT",
          "is_baseline": true,
          "description": "Multipl-T ground-truth Lua corpus. Saved internally as 'multipl-t'.",
          "dataset_path": "datasets/multipl-t/lua-00000-of-00001.parquet"
        },
        {
          "name": "deepseek-sm-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/deepseek-sm-he.csv"
        },
        {
          "name": "deepseek-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/deepseek-he.csv"
        },
        {
          "name": "gpt-4o-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/gpt-4o-he.csv"
        },
        {
          "name": "gpt-4o-mini-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/gpt-4o-mini-he.csv"
        },
        {
          "name": "llama-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/llama-he.csv"
        },        
        {
          "name": "llama-sm-he",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "humanEval",
          "dataset_path": "datasets/lua_multipl-e_generated/humanEval/llama-sm-he.csv"
        },
        {
          "name": "deepseek-sm-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/deepseek-sm-mbpp.csv"
        },
        {
          "name": "llama-sm-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/llama-sm-mbpp.csv"
        },
        {
          "name": "deepseek-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/deepseek-mbpp.csv"
        },
        {
          "name": "gpt-4o-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/gpt-4o-mbpp.csv"
        },
        {
          "name": "gpt-4o-mini-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/gpt-4o-mini-mbpp.csv"
        },
        {
          "name": "llama-mbpp",
          "run_class": "GeneratedLuaMultiplE",
          "folder": "mbpp",
          "dataset_path": "datasets/lua_multipl-e_generated/mbpp/llama-mbpp.csv"
        }
      ],
      "keywords": {
        "source": "semantic_groups_json",
        "excluded_keywords_path": "languages/lua/keywords/excluded_keywords.json",
        "semantic_groups_path": "languages/lua/keywords/semantic_groups.json"
      },
      "result_writer": {
        "datasets": [
          "multipl-t",
          "deepseek-he", "gpt-4o-he", "gpt-4o-mini-he", "llama-he",
          "deepseek-sm-he", "llama-sm-he",
          "deepseek-mbpp", "gpt-4o-mbpp", "gpt-4o-mini-mbpp", "llama-mbpp",
          "deepseek-sm-mbpp", "llama-sm-mbpp"
        ],
        "ds_groups": {
          "LLM Generation - Multipl-E (HumanEval)": [
            "deepseek-he", "gpt-4o-he", "gpt-4o-mini-he", "llama-he",
            "deepseek-sm-he", "llama-sm-he"
          ],
          "LLM Generation - Multipl-E (MBPP)": [
            "deepseek-mbpp", "gpt-4o-mbpp", "gpt-4o-mini-mbpp", "llama-mbpp",
            "deepseek-sm-mbpp", "llama-sm-mbpp"
          ],
          "Dataset test - Multipl-T": ["multipl-t"]
        }
      }
    },

    "ocl": {
      "run_module": "ocl",
      "grammar": {
        "lexer_g4": "languages/ocl/parser/OCL.g4",
        "parser_g4": "languages/ocl/parser/OCL.g4"
      },
      "datasets": [
        {
          "name": "BaseLine.json",
          "run_class": "BaseLineAnalysis",
          "is_baseline": true,
          "description": "Abukhalaf et al. 2023 ground-truth OCL corpus. Saved as 'BaseLine' (extension stripped by class).",
          "dataset_path": "datasets/OCL_ds/BaseLine.json"
        },
        {
          "name": "gpt-4o",
          "run_class": "GeneratedOCL",
          "description": "GPT-4o OCL generation. Class applies filters: LANGUAGE=OCL and TASK!=-1.",
          "dataset_path": "datasets/OCL_ds_generated/gpt-4o.csv"
        },
        {
          "name": "gpt-4o-mini",
          "run_class": "GeneratedOCL",
          "dataset_path": "datasets/OCL_ds_generated/gpt-4o-mini.csv"
        },
        {
          "name": "deepseek",
          "run_class": "GeneratedOCL",
          "dataset_path": "datasets/OCL_ds_generated/deepseek.csv"
        },
        {
          "name": "llama",
          "run_class": "GeneratedOCL",
          "dataset_path": "datasets/OCL_ds_generated/llama.csv"
        },
        {
          "name": "llama-sm",
          "run_class": "GeneratedOCL",
          "dataset_path": "datasets/OCL_ds_generated/llama-sm.csv"
        },
        {
          "name": "deepseek-sm",
          "run_class": "GeneratedOCL",
          "dataset_path": "datasets/OCL_ds_generated/deepseek-sm.csv"
        },
        {
          "name": "Pan_et_al.json",
          "run_class": "PanOCLDataset",
          "is_baseline": true,
          "description": "Pan et al. 2024 OCL dataset. Saved as 'Pan_et_al' (extension stripped by class).",
          "dataset_path": "datasets/OCL_ds2/Pan_et_al.json"
        }
      ],
      "keywords": {
        "source": "semantic_groups_json",
        "excluded_keywords_path": "languages/ocl/keywords/excluded_keywords.json",
        "semantic_groups_path": "languages/ocl/keywords/semantic_groups.json"
      },
      "result_writer": {
        "datasets": [
          "BaseLine",
          "deepseek", "gpt-4o", "gpt-4o-mini", "llama", "llama-sm", "deepseek-sm",
          "Pan_et_al"
        ],
        "ds_groups": {
          "LLM Generation - Abukhalaf et al., 2023": [
            "BaseLine", "deepseek", "llama", "gpt-4o", "gpt-4o-mini",
            "llama-sm", "deepseek-sm"
          ],
          "Dataset test - Pan et al., 2024": ["Pan_et_al"]
        }
      }
    },

    "plantuml": {
      "run_module": "plantuml",
      "grammar": {
        "lexer_g4": "languages/plantuml/parser/PlantUMLLexer.g4",
